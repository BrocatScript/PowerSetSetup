QComboBox:focus {
    border-color: #2b4764;
}

QComboBox::placeholder {
    color: #6e7d8d;
}

QComboBox {
    background-color: #1b2d3f;
    color: #ffffff;
    border: 2px solid #162a3c;
    border-radius: 10px;
    padding: 4px 14px;
    font-size: 16px;
    selection-background-color: #5288c1;
}

QComboBox::drop-down {
    background: none;      /* убираем фон контейнера */
    border: none;          /* убираем рамку контейнера */
    subcontrol-position: right center;
    subcontrol-origin: padding;
}

QComboBox::down-arrow {
    image: url(:/Icons_svg/data/icons/arrow_down.svg);
    width: 24px;
    height: 24px;
    subcontrol-position: right center;
    subcontrol-origin: padding;
}

QComboBox QAbstractItemView::item {
    min-height: 20px;   /* Минимальная высота пункта. Экспериментируйте с этим значением (например, 20, 24, 28) */
    padding: 2px 8px;   /* Внутренние отступы для текста, чтобы он не прилипал к краям */
}</string>
